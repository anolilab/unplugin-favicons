    "bugs": {
        "url": "https://github.com/anolilab/unplugin-favicons/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/anolilab/unplugin-favicons.git"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/prisis"
        },
        {
            "type": "consulting",
