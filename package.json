{
    "name": "@anolilab/unplugin-favicons",
    "version": "2.0.0",
    "description": "Generate favicons for your project with caching for blazing fast rebuilds.",
    "keywords": [
        "plugin",
        "pwa",
        "vite-plugin",
        "vite",
        "favicon",
        "favicons",
        "image",
        "generate",
        "webpack",
        "rspack",
        "rollup",
        "astro",
        "esbuild",
        "nuxt",
        "sveltekit",
        "svelte",
        "generating-favicons",
        "favicons-generator"
    ],
